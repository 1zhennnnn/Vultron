# Groq AI API key — get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Neon PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host/database
DATABASE_URL=postgresql+asyncpg://user:password@host/database

# Frontend origin for CORS (set to your Vercel URL after deployment)
FRONTEND_URL=https://your-project.vercel.app

# JWT secret for token signing — change this to a long random string in production
JWT_SECRET=vultron-change-this-secret-key

# Backend port (Railway sets $PORT automatically — leave as 8000 for local)
PORT=8000

# Path to solc binary (leave empty in Docker — uses /usr/local/bin/solc)
# On Windows local dev: C:/Users/yourname/solc.exe
# SOLC_PATH=
